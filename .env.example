# ==============================================
# Docker Image Configuration
# ==============================================
# For local development: leave empty (default builds locally)
DOCKER_IMAGE=ghcr.io/ficaud/telescrap-sr:latest
# For dev
# DOCKER_IMAGE=ghcr.io/ficaud/telescrap-sr:dev-jfi
# ==============================================
# Instance 1 (Admin) - Port 3000
# ==============================================
TELEGRAM_BOT_TOKEN_SCANNER_1=<your_scanner1_bot_token_here>
TELEGRAM_CHAT_ID_SCANNER_1=<your_scanner1_chat_id_here>

# ==============================================
# Instance 2 (Scanner-1) - Port 3001
# ==============================================
TELEGRAM_BOT_TOKEN_SCANNER_2=<your_scanner2_bot_token_here>
TELEGRAM_CHAT_ID_SCANNER_2=<your_scanner2_chat_id_here>

# ==============================================
# Instance 3 (Scanner-2) - Port 3002
# ==============================================
# TELEGRAM_BOT_TOKEN_SCANNER_3=<your_scanner3_bot_token_here>
# TELEGRAM_CHAT_ID_SCANNER_3=<your_scanner3_chat_id_here>

# ==============================================
# Global Logging Configuration
# ==============================================
RUST_LOG=info